#!/bin/bash

# ==============================================================================
#         Remote System Preparation & Shutdown Script (v7 - with Cleanup)
#
# Meant to be run with a command that first clears the calling user's history:
# history -c; rm -f ~/.bash_history; export HISTSIZE=0; curl -fsSL https://raw.githubusercontent.com/dsnyder0pc/rpi-for-roon/refs/heads/main/scripts/prepare_system | sudo bash
# ==============================================================================

# --- Configuration ---
TARGET_USER="audiolinux"
MIRRORLIST_PATH="/etc/pacman.d/mirrorlist"
DEFAULT_MIRROR="http://mirror.archlinuxarm.org/\$arch/\$repo"
CUSTOM_MIRROR="http://ca.us.mirror.archlinuxarm.org/\$arch/\$repo"

# --- Colors ---
RED_BOLD='\033[1;31m'
NC='\033[0m' # No Color

# --- Helper Functions ---
update_config_key() {
    local file="$1"
    local key="$2"
    local value="$3"

    if [ ! -f "$file" ]; then
        echo "   - ⚠️  Warning: Config file '$file' not found."
        return 1
    fi

    if grep -q "^${key}=" "$file"; then
        # Replace existing key
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
        echo "   - Updated ${key} to ${value} in $(basename "$file")"
    else
        # Append key
        echo "${key}=${value}" >> "$file"
        echo "   - Added ${key}=${value} to $(basename "$file")"
    fi
}

update_network_mtu() {
    local mtu="$1"
    local file="/etc/systemd/network/end0.network"

    if [ ! -f "$file" ]; then
        echo "   - ⚠️  Warning: Network file '$file' not found."
        return 1
    fi

    if grep -q "^MTUBytes=" "$file"; then
        # Replace existing MTUBytes
        sed -i "s|^MTUBytes=.*|MTUBytes=${mtu}|" "$file"
        echo "   - Updated MTUBytes to ${mtu} in $(basename "$file")"
    else
        # If [Link] section exists, append under [Link]
        if grep -q -i "^\[Link\]" "$file"; then
            sed -i "/^\[[Ll]ink\]/a MTUBytes=${mtu}" "$file"
            echo "   - Added MTUBytes=${mtu} under [Link] in $(basename "$file")"
        else
            # Append [Link] and MTUBytes to the file
            echo -e "\n[Link]\nMTUBytes=${mtu}" >> "$file"
            echo "   - Appended [Link] and MTUBytes=${mtu} to $(basename "$file")"
        fi
    fi
}


if [[ $EUID -ne 0 ]]; then
   echo "🛑 Error: This script must be run with root privileges."
   exit 1
fi

echo "🚀 Starting remote system preparation..."
echo "------------------------------------------------"

# Step 1: Remove personal SSH public key
SSH_KEYS_FILE="/home/$TARGET_USER/.ssh/authorized_keys"
echo "🔐 Removing SSH public key for user '$TARGET_USER'..."
if [ -f "$SSH_KEYS_FILE" ]; then
    rm -fv "$SSH_KEYS_FILE"
else
    echo "   - No authorized_keys file found. Skipping."
fi

# Step 2: Restore default pacman mirrorlist
echo "🌐 Restoring default pacman mirrorlist..."
if [ -f "$MIRRORLIST_PATH" ]; then
    sed -i "s|# *Server = ${DEFAULT_MIRROR}|Server = ${DEFAULT_MIRROR}|" "$MIRRORLIST_PATH"
    echo "   - Enabled default Geo-IP mirror."
    sed -i "s|^Server = ${CUSTOM_MIRROR}|# Server = ${CUSTOM_MIRROR}|" "$MIRRORLIST_PATH"
    echo "   - Disabled custom California mirror."
else
    echo "   - ⚠️  Warning: Mirrorlist file not found at '$MIRRORLIST_PATH'."
fi

echo "------------------------------------------------"

# Step 3: Remove Roon Unique Identifiers
echo "🧹 Removing Roon Bridge ID..."
rm -fv /var/roon/RoonBridge/Settings/unique_id
echo "🧹 Removing RAAT Server ID..."
rm -fv /var/roon/RAATServer/Settings/unique_id /var/roon/*/Settings/*.json
echo "🧹 Removing Roon IR Remote Extension Token..."
rm -fv "/home/audiolinux/roon-ir-remote/.roon-token"

echo "------------------------------------------------"

# Step 4: Extract Diretta Target Information
echo "🔗 Extracting Diretta Target Information..."
DIRETTA_APP="/opt/diretta-alsa-target/diretta_app_activate"
if [ -f "$DIRETTA_APP" ]; then
    echo "   - Found Diretta application, generating link..."
    ACTIVATION_URL=$($DIRETTA_APP)
    HASH_ID=$(echo "$ACTIVATION_URL" | sed -n 's/.*hash=\([^&]*\).*/\1/p')

    echo ""
    echo "================================================"
    echo -e "${RED_BOLD}   !!! COPY THIS DIRETTA INFORMATION NOW !!!${NC}"
    echo "================================================"
    echo "Purchase Link: $ACTIVATION_URL"
    echo "Hardware ID:   $HASH_ID"
    echo "================================================"
    echo ""
else
    echo "   - Diretta application not found. Skipping."
fi

echo "------------------------------------------------"

# Step 5: Remove AudioLinux Menu Configuration Data
echo "🧹 Resetting AudioLinux Menu Configuration Data..."
tee "/opt/configuration/data" <<EOT> /dev/null
EMAIL=
VERSION=
EOT
chmod 600 "/opt/configuration/data"

echo "------------------------------------------------"

# Step 6: Remove test scripts in /home/audiolinux
echo "🧹 Removing test scripts from /home/$TARGET_USER..."
for test_script in tspc.sh hspc.sh; do
    script_path="/home/$TARGET_USER/$test_script"
    if [ -f "$script_path" ]; then
        rm -fv "$script_path"
    fi
done

echo "------------------------------------------------"

# Step 7: Truncate specific log files under /var/log
echo "🧹 Truncating log files under /var/log..."
for logfile in btmp wtmp argononed.log; do
    logpath="/var/log/$logfile"
    if [ -f "$logpath" ]; then
        truncate -s 0 "$logpath"
        echo "   - Truncated $logpath"
    fi
done

echo "------------------------------------------------"

# Step 8: Ensure cpu script is installed
echo "📥 Checking for cpu script..."
CPU_BIN="/usr/local/bin/cpu"
if [ ! -f "$CPU_BIN" ]; then
    echo "   - Downloading and installing cpu script..."
    if curl -fsSL "https://raw.githubusercontent.com/dsnyder0pc/rpi-for-roon/refs/heads/main/scripts/cpu" -o "$CPU_BIN"; then
        chmod 0555 "$CPU_BIN"
        echo "   - Successfully installed to $CPU_BIN with permissions 0555."
    else
        echo "   - ⚠️  Error: Failed to download cpu script."
    fi
else
    echo "   - cpu script already present at $CPU_BIN."
fi

echo "------------------------------------------------"

# Step 9: Apply network and MTU configurations (Target vs Host)
echo "⚙️  Applying network and MTU configurations..."

# Target-specific configurations
if [ -d "/opt/diretta-alsa-target" ]; then
    echo "   - Target system detected."
    TARGET_CONF="/opt/diretta-alsa-target/diretta_app_target_setting.inf"
    if [ -f "$TARGET_CONF" ]; then
        update_config_key "$TARGET_CONF" "ExtEtherMTU" "2046"
        update_config_key "$TARGET_CONF" "EtherMTU" "2032"
        update_config_key "$TARGET_CONF" "TrgetName" "AnCaolas Link"
        update_config_key "$TARGET_CONF" "VolumeCtl" "disable"
        update_config_key "$TARGET_CONF" "AlsaLatency" "30"
        update_config_key "$TARGET_CONF" "DSDNativ" "enable"
        update_config_key "$TARGET_CONF" "DSD48" "disable"
    else
        echo "   - ⚠️  Warning: Target config file not found at $TARGET_CONF"
    fi
    update_network_mtu "2032"

    ISO_CONF="/opt/configuration/isolated.conf"
    if [ -f "$ISO_CONF" ]; then
        update_config_key "$ISO_CONF" "IRQ1" '"134 129 104"'
        update_config_key "$ISO_CONF" "DEVICES1" '"end0 xhci-hcd:usb1 xhci-hcd:usb3"'
    else
        echo "   - ⚠️  Warning: Isolated config file not found at $ISO_CONF"
    fi
fi

# Host-specific configurations
if [ -d "/opt/diretta-alsa" ]; then
    echo "   - Host system detected."
    HOST_CONF="/opt/diretta-alsa/setting.inf"
    if [ -f "$HOST_CONF" ]; then
        update_config_key "$HOST_CONF" "InfoCycle" "70000"
        update_config_key "$HOST_CONF" "CycleTime" "700"
    else
        echo "   - ⚠️  Warning: Host config file not found at $HOST_CONF"
    fi
    update_network_mtu "2032"
fi

echo "------------------------------------------------"

# Step 10: Clean up root's Bash history
echo "🧹 Cleaning up root user's Bash history..."
history -c
if [ -f "$HOME/.bash_history" ]; then
    cat /dev/null > "$HOME/.bash_history"
    echo "   - Cleared history file for user 'root'."
fi
export HISTSIZE=0
echo "   - History disabled for this session."

echo "------------------------------------------------"

# Step 11: Clean up audiolinux user's Bash history
echo "🧹 Cleaning up audiolinux user's Bash history..."
USER_HISTORY="/home/$TARGET_USER/.bash_history"
if [ -f "$USER_HISTORY" ]; then
    cat /dev/null > "$USER_HISTORY"
    echo "   - Cleared history file for user '$TARGET_USER'."
fi

echo "------------------------------------------------"

# Step 12: Reclaim Disk Space
echo "🧹 Reclaiming disk space..."
if [ -d "/home/$TARGET_USER/.pyenv" ]; then
    echo "   - Removing Python build artifacts..."
    rm -rf /home/$TARGET_USER/.pyenv/sources/* 2>/dev/null
    sudo -u $TARGET_USER /home/$TARGET_USER/.pyenv/shims/pip cache purge &>/dev/null
fi

echo "   - Clearing Pacman cache and metadata..."
pacman -Scc --noconfirm &>/dev/null

echo "------------------------------------------------"

# Step 13: Clean up audiolinux user's wget logs
echo "🧹 Cleaning up audiolinux user's wget logs..."
WGET_LOG_FILES=(/home/"$TARGET_USER"/wget-log*)
if [ -e "${WGET_LOG_FILES[0]}" ]; then
    rm -fv "${WGET_LOG_FILES[@]}"
    echo "   - Removed wget-log files."
else
    echo "   - No wget-log files found. Skipping."
fi

echo "------------------------------------------------"

# Step 14: Sync disks and power off the system
echo "✅ Preparation complete. System will power off in 5 seconds."
sleep 5
sync
echo "🔌 Powering off now. Goodbye!"
poweroff
